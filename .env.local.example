# Copy this file to .env.local and fill in your real keys

# Get from aistudio.google.com -> Get API key
GEMINI_API_KEY=your_gemini_api_key_here

# Get from supabase.com -> your project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# --- Optional AI fallback chain ---
# If Gemini fails or hits its rate limit, the app automatically tries these in order.
# Leave any of these blank and that provider is just skipped — the app works fine with
# only GEMINI_API_KEY set, exactly as before. Each one is free to sign up for, no card needed.

# Get from console.groq.com -> API Keys
GROQ_API_KEY=

# Get from openrouter.ai -> Keys
OPENROUTER_API_KEY=

# Get from cloud.cerebras.ai -> API Keys
CEREBRAS_API_KEY=

# Optional: override the default model for any fallback provider without a code change,
# in case a provider retires or renames a free model.
# GROQ_MODEL=llama-3.3-70b-versatile
# OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
# CEREBRAS_MODEL=gpt-oss-120b

# --- Optional error monitoring (Sentry) ---
# Without these set, Sentry.init() is a safe no-op — nothing breaks, errors just aren't
# reported anywhere. Sign up free at sentry.io (no card needed for the free tier), create
# a Next.js project, then fill these in from Settings -> Client Keys (DSN) and an org-level
# auth token (Settings -> Auth Tokens -> Create New Token, needs project:releases scope).

# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=
# SENTRY_AUTH_TOKEN=

# --- Chrome extension: in-popup scoring ---
# Required for the extension's "Score instantly" feature to work — without it, the
# extension's API requests get rejected by CORS and it silently falls back to the
# normal "Open in Cvly" flow (safe, just without the extra feature).
# Comma-separated list of allowed extension IDs. While testing locally: go to
# chrome://extensions, find "Cvly — Job Match Checker", copy the ID shown under it.
# Once published to the Chrome Web Store, add that permanent ID here too (both can be
# listed at once during the transition).
# ALLOWED_EXTENSION_IDS=your_local_test_id_here

# --- Razorpay billing (Phase 5) ---
# RAZORPAY_KEY_ID and RAZORPAY_KEY_SECRET come from Razorpay Dashboard -> Settings -> API Keys.
# rzp_live_... = live mode (real money). rzp_test_... = test mode.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Create Plans in Razorpay Dashboard -> Subscriptions -> Plans first (see setup notes),
# then paste the plan_id values here. Nothing works without these.
RAZORPAY_PLAN_ID_PRO_MONTHLY=
RAZORPAY_PLAN_ID_PRO_YEARLY=

# Generated when you register the webhook URL in Razorpay Dashboard -> Settings ->
# Webhooks. URL to register: https://cvly.in/api/billing/webhook
# Events to select: subscription.authenticated, subscription.activated,
# subscription.charged, subscription.pending, subscription.halted,
# subscription.cancelled, subscription.completed, order.paid (the last one is for
# one-time credit top-up purchases, not subscriptions)
RAZORPAY_WEBHOOK_SECRET=

# --- Meta Pixel + Conversions API ---
# NEXT_PUBLIC_ because the Pixel ID is used client-side (it's not a secret).
NEXT_PUBLIC_META_PIXEL_ID=
# The CAPI access token IS a secret — server-side only, no NEXT_PUBLIC_ prefix.
META_CAPI_ACCESS_TOKEN=
# META_PIXEL_ID (no NEXT_PUBLIC_) is a separate copy used only by server-side CAPI
# calls — same value as NEXT_PUBLIC_META_PIXEL_ID, kept as two vars so the server
# code never accidentally depends on a client-exposed env var.
META_PIXEL_ID=
# Optional, temporary — set this while verifying in Events Manager's Test Events
# tab, then remove it once confirmed working so real events stop routing to test.
# META_TEST_EVENT_CODE=

